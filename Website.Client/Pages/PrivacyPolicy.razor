@page "/privacy-policy"

@namespace Website.Client

@inherits ComponentBase


<HeadAndMetaContent PageTitle="Privacy Policy" Description="Dioptra's Privacy Policy." OpenGraphImage=""
                    TwitterImage="">
</HeadAndMetaContent>


<div class="dw-section-regular">
    <div class="dw-max-width-content">
        <div class="mdc-layout-grid">
            <div class="mdc-layout-grid__inner">
                <div class="mdc-layout-grid__cell--span-12">
                    <h2 class="mdc-typography--headline1">Privacy Policy</h2>
                    <p class="mdc-typography--body1">Last updated: 22 May 2026.</p>
                    <p class="mdc-typography--body1">This website is operated by Dioptra Limited. This page explains
                        what personal data we process, why we process it, and how the website uses cookies and similar
                        storage.</p>

                        <h3 class="mdc-typography--headline4">Information we process</h3>
                        <p class="mdc-typography--body1">If you contact us through this website, we process the information
                            you provide in your message, such as your name, email address, phone number, and the contents of
                            your enquiry.</p>
                            <p class="mdc-typography--body1">We also process limited technical data needed to operate and secure
                                the website, such as server logs, request metadata, and security-related telemetry.</p>

                                <h3 class="mdc-typography--headline4">Cookies and similar storage</h3>
                                <p class="mdc-typography--body1">We use strictly necessary storage to make the website function and
                                    to remember your cookie preferences. These items are used because the site cannot reliably
                                    provide the requested service without them.</p>
                                    <p class="mdc-typography--body1">We use Google Analytics only if you choose to allow analytics
                                        cookies. Until you opt in, non-essential analytics is disabled.</p>

                                        <h3 class="mdc-typography--headline4">Managing your preferences</h3>
                                        <p class="mdc-typography--body1">You can change your cookie choice at any time by selecting Cookie
                                            settings in the footer. If you reject non-essential cookies, the site will continue to work with
                                            only strictly necessary storage enabled.</p>

                                            <h3 class="mdc-typography--headline4">Why we process personal data</h3>
                                            <p class="mdc-typography--body1">We process enquiry data so we can respond to requests about our
                                                business and services. We process essential technical data to run, secure, and maintain the
                                                website. If you consent to analytics, we process analytics data to understand aggregate website
                                                usage and improve the site.</p>

                                                <h3 class="mdc-typography--headline4">Your rights</h3>
                                                <p class="mdc-typography--body1">Depending on where you are located, you may have rights to request
                                                    access to your personal data, ask for correction or deletion, object to certain processing, or
                                                    withdraw consent for optional analytics at any time.</p>

                                                    <h3 class="mdc-typography--headline4">Contact</h3>
                                                    <p class="mdc-typography--body1">For privacy-related questions, please contact Dioptra Limited using
                                                        the website contact form or by post at Preston Park House, South Road, Brighton, East Sussex BN1
                                                        6SB, United Kingdom.</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
